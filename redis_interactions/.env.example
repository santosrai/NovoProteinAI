
REDIS_HOST=YOUR_HOST
REDIS_PORT=YOUR_PORT
REDIS_USERNAME=default
REDIS_PASSWORD=YOUR_PASSWORD
# Set to true for managed Redis that requires TLS (connects over rediss://).
REDIS_TLS=false

# Vector index config
REDIS_INDEX_NAME=idx:papers
REDIS_KEY_PREFIX=chunk:

# Embedding model (open weights). EMBEDDING_DIM MUST match the model:
#   google/embeddinggemma-300m       -> 768
#   sentence-transformers/all-MiniLM-L6-v2 -> 384
EMBEDDING_MODEL=google/embeddinggemma-300m
EMBEDDING_DIM=768
