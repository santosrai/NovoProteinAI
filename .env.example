# PyMOL MCP Bridge Configuration

# PyMOL plugin host
PYMOL_HOST=localhost

# PyMOL plugin port
PYMOL_PORT=9877

# Request timeout in seconds
PYMOL_TIMEOUT=30.0

# Number of reconnection attempts
PYMOL_RECONNECT_ATTEMPTS=3

# Initial reconnection delay in seconds (exponential backoff)
PYMOL_RECONNECT_DELAY=1.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
PYMOL_LOG_LEVEL=INFO

# --- PyMOL tool transport (src/agent_graph.py) ---
# How the agent reaches PyMOL:
#   relay  (default) - PUBLIC deployment: PyMOL connects out to the cloud relay.
#                      Use this when deploying the agent on Railway.
#   mcp              - LOCAL dev: spawn pymol_mcp MCP server over stdio.
#   local/direct     - LOCAL dev: direct localhost TCP to the plugin (9877).
PYMOL_TRANSPORT=relay

# --- PyMOL backend: local vs cloud (src/agent_graph.py) ---
# Selects which PyMOL the agentic brain uses for visualization:
#   false (default) - LOCAL PyMOL: the agent drives the PyMOL on your machine
#                     (via PYMOL_TRANSPORT above). The interactive cloud-GUI
#                     tools are NOT offered.
#   true            - CLOUD PyMOL: the agent boots a live PyMOL GUI on RunPod
#                     (noVNC) and shares a browser link. Requires the RunPod
#                     vars below. To also DRIVE the cloud session, the cloud
#                     PyMOL must reach the relay (set PUBLIC_RELAY_URL; locally
#                     that means exposing your relay via a tunnel).
PYMOL_CLOUD=false

# Port the relay/agent web service binds to. Railway injects PORT automatically.
PORT=8000

# --- Research agent (src/research_agent.py) ---

# Fixed seed phrase -> stable agent address across restarts (required to run)
AGENT_SEED=change-me-to-a-fixed-phrase

# Agentverse API key (Profile -> API Keys). Used to register the agent AND to
# upload rendered PyMOL screenshots to Agentverse storage so they show inline
# in chat. Without it, the agent still replies with text + the viewer link.
AGENTVERSE_KEY=

# ASI:One API key for goal parsing + explanation drafting.
# Optional: if unset, the agent uses a keyword fallback.
ASI_ONE_API_KEY=

# Anthropic (Claude) powers the agentic LangGraph brain.
# Required to enable the agentic loop; without it the agent falls back to the
# deterministic research + command router.
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-3-5-sonnet-latest)
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Conversation memory: how many recent chat messages (user+assistant) to keep
# per session so the agent remembers context. Only compact text is stored (not
# tool traces), so token cost stays low. Default 12 (~6 exchanges); set 0 to
# disable memory entirely.
MAX_HISTORY_MESSAGES=12

# --- Interactive cloud GUI (RunPod Serverless, src/runpod_gui.py) ---
# Opt-in mode: the agent boots a live PyMOL GUI over noVNC on RunPod and returns
# a clickable browser link. Both vars are required to enable the launch/close
# tools; if unset, the tools report the feature is not configured.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
# HTTP port exposed by the endpoint template (must match runpod_gui/Dockerfile).
RUNPOD_GUI_PORT=8080
# Seconds the agent waits for the worker to stream back the viewer URL.
RUNPOD_GUI_POLL_TIMEOUT=90
# Agent control of the cloud session (optional). Public WebSocket URL of THIS
# app's relay; the cloud PyMOL dials out to it so the agent's relay tools can
# drive the live session. Must be the deployed relay (e.g. Railway), reachable
# from RunPod. If unset, the cloud GUI is launch-only (user-driven).
#   e.g. PUBLIC_RELAY_URL=wss://your-app.up.railway.app/plugin
PUBLIC_RELAY_URL=
