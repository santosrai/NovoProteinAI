# PyMOL MCP Bridge Configuration

# PyMOL plugin host
PYMOL_HOST=localhost

# PyMOL plugin port
PYMOL_PORT=9877

# Request timeout in seconds
PYMOL_TIMEOUT=30.0

# Number of reconnection attempts
PYMOL_RECONNECT_ATTEMPTS=3

# Initial reconnection delay in seconds (exponential backoff)
PYMOL_RECONNECT_DELAY=1.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
PYMOL_LOG_LEVEL=INFO

# --- Research agent (src/research_agent.py) ---

# Fixed seed phrase -> stable agent address across restarts (required to run)
AGENT_SEED=change-me-to-a-fixed-phrase

# ASI:One API key for goal parsing + explanation drafting.
# Optional: if unset, the agent uses a keyword fallback.
ASI_ONE_API_KEY=

# Anthropic (Claude) powers the agentic LangGraph brain.
# Required to enable the agentic loop; without it the agent falls back to the
# deterministic research + command router.
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-3-5-sonnet-latest)
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
